{
  "manifest": {
    "id": "apple-hello",
    "name": { "default": "Apple Hello", "zh": "Apple 你好", "ja": "Apple こんにちは" },
    "description": {
      "default": "Smoke test for corelet-apple-runtime — renders MVP components natively.",
      "zh": "corelet-apple-runtime 冒烟测试 —— 用 SwiftUI 原生渲染 MVP 组件。",
      "ja": "corelet-apple-runtime のスモークテスト —— SwiftUI でネイティブ描画。"
    },
    "version": "1.0.0",
    "runtime": "apple",
    "permissions": [],
    "author": "agent-rt",
    "category": "developer-tools",
    "keywords": ["apple", "runtime", "smoke"],
    "window": { "style": "phone", "width": 360, "height": 560 }
  },
  "ui": {
    "type": "Page",
    "props": { "title": "Apple Hello" },
    "children": [
      {
        "type": "VStack",
        "props": { "gap": 12 },
        "children": [
          {
            "type": "Heading",
            "props": { "content": "Native renderer is live", "level": 2 }
          },
          {
            "type": "Text",
            "props": {
              "content": "If you can read this without a WebView in sight, the bridge → IR → SwiftUI pipeline works.",
              "color": "secondary"
            }
          },
          { "type": "Divider" },
          {
            "type": "Section",
            "props": { "title": "MVP component sampler" },
            "children": [
              {
                "type": "VStack",
                "props": { "gap": 8 },
                "children": [
                  { "type": "Text", "props": { "content": "Stack + Spacer + Divider — containers ✓" } },
                  {
                    "type": "HStack",
                    "props": { "gap": 8 },
                    "children": [
                      { "type": "Text", "props": { "content": "HStack:" } },
                      { "type": "Text", "props": { "content": "left" } },
                      { "type": "Spacer" },
                      { "type": "Text", "props": { "content": "right", "color": "secondary" } }
                    ]
                  },
                  { "type": "Divider" },
                  {
                    "type": "Progress",
                    "props": { "value": 0.7, "max": 1 }
                  },
                  { "type": "Text", "props": { "content": "Progress bar 70%", "color": "secondary" } }
                ]
              }
            ]
          },
          { "type": "Divider" },
          {
            "type": "Section",
            "props": { "title": "Buttons (colors)" },
            "children": [
              {
                "type": "HStack",
                "props": { "gap": 8 },
                "children": [
                  { "type": "Button", "props": { "label": "Primary", "color": "primary" } },
                  { "type": "Button", "props": { "label": "Success", "color": "success" } },
                  { "type": "Button", "props": { "label": "Danger", "color": "danger" } }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
