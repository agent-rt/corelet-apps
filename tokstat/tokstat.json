{
  "manifest": {
    "id": "tokstat",
    "name": "AI Token Usage",
    "description": "Claude + Codex session/weekly usage in your menu bar. Claude: PTY-spawns `claude /usage` per minute. Codex: reads ~/.codex/sessions rollout JSONL (no subprocess). Menubar shows two lines `CL <s>·<w>` and `CX <s>·<w>`; popover breaks each side out with progress bars + reset countdowns.",
    "version": "0.2.0",
    "runtime": "web",
    "requires": [
      { "plugin": "tokstat", "version": ">=0.2" }
    ],
    "permissions": [
      "data:read",
      "data:write"
    ],
    "collections": {
      "samples": {
        "storage": "persistent",
        "schema": {
          "ts": { "type": "integer" },
          "source": { "type": "string" },
          "ok": { "type": "boolean" },
          "session_pct": { "type": "integer" },
          "weekly_pct": { "type": "integer" },
          "session_resets_ms": { "type": "integer" },
          "weekly_resets_ms": { "type": "integer" },
          "total_cost_usd": { "type": "number" }
        }
      }
    },
    "jobs": [
      {
        "id": "on_sample",
        "trigger": { "kind": "event", "event": "tokstat.sample" },
        "while": "always",
        "handler": "onSample"
      }
    ],
    "window": {
      "width": 320,
      "height": 220
    }
  },
  "ui": "tokstat.ui.tsx",
  "scripts": "tokstat.scripts.js"
}
